<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<!-- Header option for Website Builder -->
	<template id="template_header_opt" inherit_id="website.snippet_options" name="PK Hoan Hao Header Template - Option">
		<xpath expr="//we-select[@data-variable='header-template']" position="inside">
			<we-button title="PK Hoan Hao"
				data-customize-website-views="pk_hoan_hao.header"
				data-customize-website-variable="'pk_hoan_hao'"
				data-img="/pk_hoan_hao/static/description/icon.png"/>
		</xpath>
	</template>

	<!-- Custom header -->
	<record id="header" model="ir.ui.view">
		<field name="name">PK Hoan Hao header</field>
		<field name="type">qweb</field>
		<field name="key">pk_hoan_hao.header</field>
		<field name="inherit_id" ref="website.layout"/>
		<field name="mode">extension</field>
		<field name="arch" type="xml">
			<xpath expr="//header" position="replace">
				<header id="top" class="pk-header">
					<div class="pk-header-top">
                        <!-- Top Bar -->
                        <div class="pk-topbar py-2 d-none d-md-block">
                            <div class="container">
                                <div class="row align-items-center text-center text-md-start small">
                                    <div class="col-md-4 text-center">
                                        <i class="fas fa-envelope me-2"/> hoanhao@health.com
                                    </div>
                                    <div class="col-md-4 text-center">
                                        Thứ 2 - Thứ 7: 7:00 - 12:00 | 13:30 - 17:00
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <i class="fas fa-phone me-2"/> 19002115
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Main Navbar -->
                        <t t-call="website.navbar">
                            <t t-set="_navbar_classes" t-valuef="navbar navbar-expand-md bg-white sticky-top pk-navbar pk-navbar-animate"/>
                            <div class="container">
                                <!-- Logo -->
                                <t t-call="website.placeholder_header_brand">
                                    <t t-set="_link_class" t-valuef="navbar-brand d-flex align-items-center gap-3 pk-logo-link"/>
                                </t>

                                <!-- Toggler -->
                                <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#pk_mobile_menu" aria-controls="pk_mobile_menu">
                                    <i class="fas fa-bars fs-3 text-dark"/>
                                </button>

                                <!-- Desktop Menu -->
                                <div class="collapse navbar-collapse" id="pk_navbar_main">
                                    <t t-call="website.navbar_nav">
                                        <t t-set="_nav_class" t-valuef="navbar-nav mx-auto pk-nav-list"/>
                                        <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                            <t t-call="website.submenu">
                                                <t t-set="item_class" t-valuef="nav-item"/>
                                                <t t-set="link_class" t-valuef="nav-link pk-nav-link"/>
                                            </t>
                                        </t>
                                    </t>

                                    <!-- Right side Desktop -->
                                    <div class="d-none d-md-flex align-items-center gap-3 pk-nav-actions">
                                        <a class="btn btn-link text-dark p-2" href="/search">
                                            <i class="fas fa-search fs-5"/>
                                        </a>

                                        <t t-call="portal.placeholder_user_sign_in">
                                            <t t-set="_link_class" t-valuef="btn btn-link text-dark d-flex align-items-center gap-2 pk-account-link"/>
                                        </t>
                                        <t t-call="portal.user_dropdown">
                                            <t t-set="_user_name" t-value="true"/>
                                            <t t-set="_icon" t-value="true"/>
                                            <t t-set="_item_class" t-valuef="dropdown"/>
                                            <t t-set="_link_class" t-valuef="btn btn-link text-dark d-flex align-items-center gap-2 pk-account-link"/>
                                            <t t-set="_dropdown_menu_class" t-valuef="dropdown-menu-end"/>
                                        </t>

                                        <t t-call="website.placeholder_header_call_to_action">
                                            <t t-set="_link_class" t-valuef="btn btn-success px-4 py-2 rounded-pill fw-medium pk-cta"/>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>

					<!-- Mobile Offcanvas -->
					<div class="offcanvas offcanvas-end pk-offcanvas" tabindex="-1" id="pk_mobile_menu">
						<div class="offcanvas-header">
							<t t-call="website.placeholder_header_brand">
								<t t-set="_link_class" t-valuef="d-flex align-items-center gap-3 pk-logo-link"/>
							</t>
							<button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"/>
						</div>
						<div class="offcanvas-body p-0 d-flex flex-column">
							<ul class="list-unstyled mb-0 pk-mobile-menu">
								<t t-foreach="website.menu_id.child_id" t-as="submenu">
									<li>
										<a t-att-href="submenu.url" class="mobile-menu-link">
											<t t-esc="submenu.name"/>
										</a>
									</li>
								</t>
							</ul>

							<div class="p-4 mt-auto">
								<t t-call="website.placeholder_header_call_to_action">
									<t t-set="_link_class" t-valuef="btn btn-success w-100 py-3 rounded-pill fw-medium pk-cta"/>
								</t>
							</div>
						</div>
					</div>

					<!-- Mobile Bottom Bar -->
					<div class="fixed-bottom bg-white border-top pk-mobile-bottom-bar d-md-none">
						<div class="row g-0 text-center">
							<div class="col-4 py-3 border-end">
								<a href="tel:19002115" class="pk-bottom-link">
									<i class="fas fa-phone fs-4"/>
								</a>
							</div>
							<div class="col-4 py-3 border-end">
								<a href="/contactus" class="pk-bottom-link">
									<i class="fas fa-map-marker-alt fs-4"/>
								</a>
							</div>
							<div class="col-4 py-3 bg-success text-white fw-medium pk-bottom-cta">
								<a href="/contactus" class="text-white text-decoration-none">Đặt lịch khám</a>
							</div>
						</div>
					</div>
				</header>
			</xpath>
		</field>
	</record>
</odoo>
