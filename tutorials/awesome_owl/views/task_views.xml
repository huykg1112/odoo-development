<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Task Views -->
    <record id="view_task_kanban" model="ir.ui.view">
        <field name="name">task.task.kanban</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status_id" class="o_kanban_small_column"
                records_draggable="true">
                <field name="status_id" />
                <field name="color" />
                <field name="priority" />
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_kanban_card">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name" />
                                        </strong>
                                    </div>
                                    <field name="priority" widget="priority" />
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="description" />
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="category_id" widget="badge" />
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="date_deadline" widget="remaining_days" />
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="assignee_id" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_task_tree" model="ir.ui.view">
        <field name="name">task.task.list</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <list decoration-danger="date_deadline and date_deadline &lt; current_date"
                decoration-muted="status_id == %(awesome_owl.status_done)d">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="status_id" />
                <field name="priority" widget="priority" />
                <field name="category_id" />
                <field name="assignee_id" />
                <field name="date_deadline" />
            </list>
        </field>
    </record>

    <record id="view_task_form" model="ir.ui.view">
        <field name="name">task.task.form</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status_id" widget="statusbar" options="{'clickable': '1'}" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Task Title..." />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" />
                            <field name="priority" widget="priority" />
                        </group>
                        <group>
                            <field name="assignee_id" />
                            <field name="date_deadline" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Add details..." />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- Status Settings View -->
    <record id="view_task_status_form" model="ir.ui.view">
        <field name="name">task.status.form</field>
        <field name="model">task.status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="sequence" />
                        </group>
                        <group>
                            <field name="color" widget="color_picker" />
                            <field name="fold" />
                        </group>
                    </group>
                    <group string="Transition Rules">
                        <field name="can_transition_to_ids" widget="many2many_tags" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Category Views -->
    <record id="view_task_category_tree" model="ir.ui.view">
        <field name="name">task.category.list</field>
        <field name="model">task.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="color" widget="color_picker" />
            </list>
        </field>
    </record>

    <record id="view_task_category_form" model="ir.ui.view">
        <field name="name">task.category.form</field>
        <field name="model">task.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="color" widget="color_picker" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_task_graph" model="ir.ui.view">
        <field name="name">task.task.graph</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <graph string="Task Analysis" type="bar" sample="1">
                <field name="status_id" />
                <field name="priority" />
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_task_calendar" model="ir.ui.view">
        <field name="name">task.task.calendar</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <calendar string="Tasks" date_start="date_deadline" color="status_id" mode="month">
                <field name="name" />
                <field name="assignee_id" />
                <field name="category_id" />
                <field name="priority" />
            </calendar>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_task_pivot" model="ir.ui.view">
        <field name="name">task.task.pivot</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <pivot string="Task Analysis" sample="1">
                <field name="status_id" type="row" />
                <field name="date_deadline" interval="month" type="col" />
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_task_search" model="ir.ui.view">
        <field name="name">task.task.search</field>
        <field name="model">task.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="assignee_id" />
                <field name="category_id" />
                <filter name="my_tasks" string="My Tasks" domain="[('user_id', '=', uid)]" />
                <separator />
                <filter name="filter_date_deadline" date="date_deadline" string="Deadline" />
                <separator />
                <filter name="overdue" string="Overdue"
                    domain="[('date_deadline', '&lt;', current_date)]" />
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status_id'}" />
                    <filter name="group_user" string="Assignee"
                        context="{'group_by': 'assignee_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Task User Views -->
    <record id="view_task_user_tree" model="ir.ui.view">
        <field name="name">task.user.list</field>
        <field name="model">task.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="email" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="view_task_user_form" model="ir.ui.view">
        <field name="name">task.user.form</field>
        <field name="model">task.user</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="email" />
                        </group>
                        <group>
                            <field name="active" />
                            <field name="color" widget="color_picker" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_task_user" model="ir.actions.act_window">
        <field name="name">Assignees</field>
        <field name="res_model">task.user</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Actions -->
    <record id="action_task_all" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">task.task</field>
        <field name="view_mode">kanban,list,form,calendar,pivot,graph</field>
        <field name="search_view_id" ref="view_task_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first task!</p>
        </field>
    </record>

    <record id="action_task_status" model="ir.actions.act_window">
        <field name="name">Status Settings</field>
        <field name="res_model">task.status</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_task_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">task.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_task_root" name="TaskFlow ERP" action="action_task_all" />
    <menuitem id="menu_task_settings" name="Settings" parent="menu_task_root" sequence="100" />
    <menuitem id="menu_task_status_settings" name="Statuses" parent="menu_task_settings"
        action="action_task_status" />
    <menuitem id="menu_task_category_settings" name="Categories" parent="menu_task_settings"
        action="action_task_category" sequence="105" />
    <menuitem id="menu_task_user_settings" name="Assignees" parent="menu_task_settings"
        action="action_task_user" sequence="110" />
</odoo>