<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.TaskManager">
        <div class="app-container">
            <!-- Sidebar -->
            <Sidebar 
                filters="state.filters"
                stats="stats"
                statusConfig="statusConfig"
                categories="categories"
                onFilterChange.bind="onFilterChange"
                onSearchInput.bind="onSearchInput"/>

            <!-- Main Content -->
            <div class="main-content">
                <!-- Top Header -->
                <header class="top-header">
                    <div class="top-header-left">
                        <h1 class="top-header-title">Task Board</h1>
                        <div class="view-toggle">
                            <button t-attf-class="view-toggle-btn {{ state.ui.activeView === 'kanban' ? 'active' : '' }}"
                                    t-on-click="() => this.setView('kanban')">
                                <i class="fa fa-th-large"/> Kanban
                            </button>
                            <button t-attf-class="view-toggle-btn {{ state.ui.activeView === 'list' ? 'active' : '' }}"
                                    t-on-click="() => this.setView('list')">
                                <i class="fa fa-list"/> List
                            </button>
                        </div>
                    </div>
                    <div class="top-header-actions">
                        <button class="btn btn-secondary" t-on-click="toggleLog">
                            <i class="fa fa-history"/> Log
                        </button>
                        <button class="btn btn-secondary" t-on-click="openSettings">
                            <i class="fa fa-cogs"/> Settings
                        </button>
                        <button class="btn btn-primary" t-on-click="openCreateForm">
                            <i class="fa fa-plus"/> Add Task
                        </button>
                    </div>
                </header>

                <!-- Date Filter -->
                <div class="filter-bar">
                    <select class="form-select filter-select" t-model="state.filters.dateRange">
                        <option value="all">All Time</option>
                        <option value="today">Today</option>
                        <option value="this_month">This Month</option>
                        <option value="this_year">This Year</option>
                        <option value="custom">Custom Range</option>
                    </select>
                    
                    <t t-if="state.filters.dateRange === 'custom'">
                        <input type="date" class="form-input date-input" t-model="state.filters.customStart"/>
                        <span class="date-sep">-</span>
                        <input type="date" class="form-input date-input" t-model="state.filters.customEnd"/>
                    </t>
                </div>

                <!-- Kanban View -->
                <t t-if="state.ui.activeView === 'kanban'">
                    <div class="kanban-board">
                        <t t-foreach="statusColumns" t-as="col" t-key="col.key">
                            <div class="kanban-column"
                                 t-on-dragover="onDragOver"
                                 t-on-drop="(ev) => this.onTaskDrop(ev, col.key)">
                                <div class="kanban-column-header">
                                    <div class="kanban-column-title">
                                        <span class="kanban-column-dot" t-attf-style="background: {{ col.color }}"/>
                                        <t t-esc="col.label"/>
                                    </div>
                                    <span class="kanban-column-count" t-esc="col.tasks.length"/>
                                </div>
                                <div class="kanban-column-body">
                                    <t t-if="col.tasks.length === 0">
                                        <div class="kanban-empty">No tasks</div>
                                    </t>
                                    <t t-foreach="col.tasks" t-as="task" t-key="task.id">
                                        <div class="task-card-wrapper" draggable="true" t-on-dragstart="(ev) => this.onTaskDragStart(ev, task)">
                                            <TaskCard
                                                task="task"
                                                statusConfig="statusConfig"
                                                statusList="statusList"
                                                onEdit.bind="openEditForm"
                                                onDelete.bind="confirmDelete"
                                                onStatusChange.bind="onStatusChange"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- List View -->
                <t t-if="state.ui.activeView === 'list'">
                    <div class="list-view">
                        <table class="list-table">
                            <thead>
                                <tr>
                                    <th t-on-click="() => this.toggleSort('title')" class="sortable">
                                        Title <i t-if="state.sort.field === 'title'" t-attf-class="fa fa-sort-{{ state.sort.order }}"/>
                                    </th>
                                    <th t-on-click="() => this.toggleSort('status')" class="sortable">
                                        Status <i t-if="state.sort.field === 'status'" t-attf-class="fa fa-sort-{{ state.sort.order }}"/>
                                    </th>
                                    <th t-on-click="() => this.toggleSort('priority')" class="sortable">
                                        Priority <i t-if="state.sort.field === 'priority'" t-attf-class="fa fa-sort-{{ state.sort.order }}"/>
                                    </th>
                                    <th t-on-click="() => this.toggleSort('category')" class="sortable">
                                        Category <i t-if="state.sort.field === 'category'" t-attf-class="fa fa-sort-{{ state.sort.order }}"/>
                                    </th>
                                    <th>Assignee</th>
                                    <th t-on-click="() => this.toggleSort('dueDate')" class="sortable">
                                        Due Date <i t-if="state.sort.field === 'dueDate'" t-attf-class="fa fa-sort-{{ state.sort.order }}"/>
                                    </th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pagedTasks" t-as="task" t-key="task.id">
                                    <tr t-on-click="() => this.openEditForm(task)">
                                        <td>
                                            <span class="list-task-title" t-esc="task.title"/>
                                        </td>
                                        <td>
                                            <span t-attf-class="badge badge-status"
                                                  t-att-style="getStatusBadgeStyle(task.status)"
                                                  t-esc="getStatusLabel(task.status)"/>
                                        </td>
                                        <td>
                                            <span t-attf-class="badge badge-priority-{{ task.priority }}"
                                                  t-esc="task.priority"/>
                                        </td>
                                        <td t-esc="getCategoryName(task.category)"/>
                                        <td t-esc="task.assignee || '—'"/>
                                        <td>
                                            <t t-if="task.dueDate">
                                                <t t-esc="new Date(task.dueDate).toLocaleDateString('vi-VN')"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td>
                                            <div class="list-actions">
                                                <button class="btn-icon" t-on-click.stop="() => this.openEditForm(task)" title="Edit">
                                                    <i class="fa fa-pencil"/>
                                                </button>
                                                <button class="btn-icon" t-on-click.stop="() => this.confirmDelete(task.id)" title="Delete" style="color: #ef4444;">
                                                    <i class="fa fa-trash"/>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="filteredTasks.length &gt; 0">
                            <div class="pagination-bar">
                                <div class="pagination-info">
                                    <t t-esc="pageInfo.from"/>-<t t-esc="pageInfo.to"/> / <t t-esc="pageInfo.total"/>
                                </div>
                                <div class="pagination-actions">
                                    <button class="btn btn-secondary" t-on-click="goPrevPage" t-att-disabled="state.pagination.page &lt;= 1">
                                        Prev
                                    </button>
                                    <span class="pagination-page">
                                        <t t-esc="state.pagination.page"/> / <t t-esc="totalPages"/>
                                    </span>
                                    <button class="btn btn-secondary" t-on-click="goNextPage" t-att-disabled="state.pagination.page &gt;= totalPages">
                                        Next
                                    </button>
                                </div>
                            </div>
                        </t>

                        <t t-if="filteredTasks.length === 0">
                            <div class="kanban-empty" style="padding: 48px; text-align: center;">
                                No tasks match your filters
                            </div>
                        </t>
                    </div>
                </t>
            </div>

            <!-- Task Form Modal -->
            <t t-if="state.ui.showForm">
                <TaskForm
                    task="state.ui.editingTask"
                    statuses="statusList"
                    categories="categories"
                    onSave.bind="onSaveTask"
                    onClose.bind="closeForm"/>
            </t>

            <!-- Activity Log Panel -->
            <t t-if="state.ui.showLog">
                <TaskLog
                    logs="state.logs"
                    onClose.bind="closeLog"/>
            </t>

            <!-- Settings Modal -->
            <t t-if="state.ui.showSettings">
                <StatusSettings
                    onClose.bind="closeSettings"
                    onUpdate.bind="loadData"/>
            </t>

            <!-- Delete Confirmation -->
            <t t-if="state.ui.showDeleteConfirm">
                <div class="confirm-overlay" t-on-click.stop="cancelDelete">
                    <div class="confirm-dialog" t-on-click.stop="() => {}">
                        <div class="confirm-dialog-title">Delete Task?</div>
                        <p class="confirm-dialog-text">This action cannot be undone. The task will be permanently removed.</p>
                        <div class="confirm-dialog-actions">
                            <button class="btn btn-secondary" t-on-click="cancelDelete">Cancel</button>
                            <button class="btn btn-danger" t-on-click="deleteTask">
                                <i class="fa fa-trash"/> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </t>

            <!-- Notifications -->
            <Notification notifications="state.notifications"/>
        </div>
    </t>
</templates>
