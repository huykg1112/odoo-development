<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="awesome_owl.playground">
        <div class="min-h-screen bg-gray-100 py-10">
            <div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-lg relative">
                
                <h2 class="text-3xl font-extrabold text-gray-800 mb-8 border-b pb-4">Quản lý Công Việc (Owl Dialog)</h2>

                <!-- Thông báo (Toast Notification) -->
                <t t-if="state.notificationText">
                    <div class="fixed top-5 right-5 px-6 py-4 rounded shadow-2xl z-50 transition drop-shadow-lg text-white font-medium"
                         t-attf-class="{{ state.notificationType === 'success' ? 'bg-green-500' : 'bg-red-500' }}">
                        <span t-esc="state.notificationText"/>
                    </div>
                </t>

                <!-- Box thêm task mới -->
                <div class="flex gap-3 mb-6">
                    <input type="text" 
                           t-ref="todo_input" 
                           placeholder="Nhập công việc cần làm..." 
                           class="flex-1 border-2 border-gray-200 rounded-lg px-4 py-2 text-lg focus:outline-none focus:border-blue-500 transition"/>
                    <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition" 
                            t-on-click="addTask">
                        Thêm mới
                    </button>
                </div>

                <!-- Danh sách công việc -->
                <ul class="space-y-3 p-0">
                   <t t-foreach="state.tasks" t-as="task" t-key="task.id">
                    <li class="flex justify-between items-center bg-gray-50 border border-gray-200 p-4 rounded-lg hover:bg-gray-100 transition shadow-sm">
                        <span t-esc="task.text" class="text-lg text-gray-700 font-medium whitespace-pre-wrap break-all"/>
                        
                        <div class="flex gap-2">
                                <!-- Nút Sửa mở Dialog -->
                            <button class="bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-1.5 px-4 rounded transition" 
                                    t-on-click="() => this.openEditDialog(task)">
                                Sửa
                            </button>
                                <!-- Nút Xóa -->
                            <button class="bg-red-500 hover:bg-red-600 text-white font-semibold py-1.5 px-4 rounded transition" 
                                    t-on-click="() => this.removeTask(task.id)">
                                Xóa
                            </button>
                        </div>
                    </li>
                   </t>
                </ul>
                
                <t t-if="state.tasks.length === 0">
                    <div class="text-center text-gray-500 mt-6 pb-4 italic">
                        Bạn chưa có công việc nào. Quá tuyệt vời! 🎉
                    </div>
                </t>

                <!-- Hộp thoại Modal (Dialog Sửa) -->
                <t t-if="state.showEditDialog">
                    <!-- Nền đen mờ -->
                    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex justify-center items-center z-40">
                        <!-- Khung Dialog trắng -->
                        <div class="bg-white p-6 rounded-xl shadow-2xl w-[450px] transform transition-all">
                            <h3 class="text-2xl font-bold mb-4 text-gray-800">Chỉnh sửa công việc</h3>

                            <!-- Ô nhập liệu của Dialog -->
                            <!-- Dùng t-model trói trực tiếp vào state.editText -->
                            <input type="text" 
                                   t-model="state.editText" 
                                   class="w-full border-2 border-gray-200 rounded px-4 py-3 mb-6 focus:outline-none focus:border-yellow-500 text-lg transition"/>

                            <!-- Nút hành động -->
                            <div class="flex justify-end gap-3">
                                <button class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2.5 px-6 rounded-lg transition" 
                                        t-on-click="closeEditDialog">Hủy bỏ</button>
                                <button class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-2.5 px-6 rounded-lg shadow-md transition" 
                                        t-on-click="saveTask">Lưu cập nhật</button>
                            </div>
                        </div>
                    </div>
                </t>

            </div>
        </div>
    </t>

</templates>