<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.TaskForm">
        <div class="modal-overlay" t-on-click="onOverlayClick">
            <div class="modal">
                <div class="modal-header">
                    <h2 class="modal-title" t-esc="formTitle"/>
                    <button class="btn-icon" type="button" t-on-click="onCancel" aria-label="Close form">
                        <i class="fa fa-times" aria-hidden="true"/>
                    </button>
                </div>

                <div class="modal-body">
                    <!-- Title -->
                    <div class="form-group">
                        <label class="form-label">Task Title *</label>
                           <input type="text" class="form-input"
                               name="title"
                               autocomplete="off"
                               placeholder="Enter task title…"
                               t-att-value="state.title"
                               t-on-input="(ev) => this.onInput('title', ev)"/>
                    </div>

                    <!-- Description -->
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea class="form-textarea" 
                                  name="description"
                                  autocomplete="off"
                                  placeholder="Describe the task…"
                                  t-on-input="(ev) => this.onInput('description', ev)"
                                  t-esc="state.description"/>
                    </div>

                    <!-- Status + Priority Row -->
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-select" 
                                    name="status"
                                    t-att-value="state.status"
                                    t-on-change="(ev) => this.onInput('status', ev)">
                                <t t-if="props.statuses">
                                    <t t-foreach="props.statuses" t-as="status" t-key="status.id">
                                        <option t-att-value="status.id" t-esc="status.name"/>
                                    </t>
                                </t>
                                <t t-else="">
                                    <option value="">Loading...</option>
                                </t>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Priority</label>
                            <select class="form-select"
                                    name="priority"
                                    t-att-value="state.priority"
                                    t-on-change="(ev) => this.onInput('priority', ev)">
                                <option value="low">Low</option>
                                <option value="medium">Medium</option>
                                <option value="high">High</option>
                                <option value="urgent">Urgent</option>
                            </select>
                        </div>
                    </div>

                    <!-- Category + Assignee Row -->
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <select class="form-select"
                                    name="category"
                                    t-att-value="state.category"
                                    t-on-change="(ev) => this.onInput('category', ev)">
                                <t t-if="props.categories">
                                    <t t-foreach="props.categories" t-as="cat" t-key="cat.id">
                                        <option t-att-value="cat.id" t-esc="cat.name"/>
                                    </t>
                                </t>
                                <t t-else="">
                                    <option value="">Loading...</option>
                                </t>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Assignee</label>
                            <select class="form-select"
                                    name="assigneeId"
                                    t-att-value="state.assigneeId"
                                    t-on-change="(ev) => this.onInput('assigneeId', ev)">
                                <option value="">Unassigned</option>
                                <t t-if="props.assignees">
                                    <t t-foreach="props.assignees" t-as="u" t-key="u.id">
                                        <option t-att-value="u.id" t-esc="u.name"/>
                                    </t>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Due Date -->
                    <div class="form-group">
                        <label class="form-label">Due Date</label>
                        <input type="date" class="form-input"
                               name="due_date"
                               t-att-value="state.dueDate"
                               t-on-input="(ev) => this.onInput('dueDate', ev)"/>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" t-on-click="onCancel">Cancel</button>
                    <button class="btn btn-primary" t-on-click="onSubmit">
                        <i t-attf-class="fa {{ isEditing ? 'fa-save' : 'fa-plus' }}" aria-hidden="true"/>
                        <t t-if="isEditing">Save Changes</t>
                        <t t-else="">Create Task</t>
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
