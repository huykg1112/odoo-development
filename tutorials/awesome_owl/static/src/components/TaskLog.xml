<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.TaskLog">
        <div class="log-panel">
            <div class="log-panel-header">
                <h3 class="log-panel-title">
                    <i class="fa fa-history"/> Activity Log
                </h3>
                <button class="btn-icon" t-on-click="props.onClose">
                    <i class="fa fa-times"/>
                </button>
            </div>
            <div class="log-panel-body">
                <t t-if="props.logs.length === 0">
                    <div class="log-empty">
                        <p>📋 No activity yet</p>
                        <p style="margin-top: 8px; font-size: 0.75rem;">Actions will be recorded here</p>
                    </div>
                </t>
                <t t-foreach="props.logs" t-as="log" t-key="log.id">
                    <div class="log-entry">
                        <div t-attf-class="log-entry-icon {{ log.action }}">
                            <i t-attf-class="fa {{ getIcon(log.action) }}"/>
                        </div>
                        <div class="log-entry-content">
                            <div class="log-entry-text" t-esc="log.details"/>
                            <div class="log-entry-time" t-esc="formatTime(log.timestamp)"/>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
