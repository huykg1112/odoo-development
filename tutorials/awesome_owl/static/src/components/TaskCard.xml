<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.TaskCard">
        <div class="task-card" role="button" tabindex="0" t-on-click="onClickEdit" t-on-keydown="onCardKeyDown">
            <!-- Header: Title + Actions -->
            <div class="task-card-header">
                <span class="task-card-title" t-esc="props.task.title"/>
                <div class="task-card-actions">
                    <button class="btn-icon" type="button" t-on-click="onClickEdit" title="Edit" aria-label="Edit task">
                        <i class="fa fa-pencil" aria-hidden="true"/>
                    </button>
                    <button class="btn-icon" type="button" t-on-click="onClickDelete" title="Delete" aria-label="Delete task" style="color: #ef4444;">
                        <i class="fa fa-trash" aria-hidden="true"/>
                    </button>
                </div>
            </div>

            <!-- Description -->
            <t t-if="props.task.description">
                <p class="task-card-description" t-esc="props.task.description"/>
            </t>

            <!-- Meta: Priority + Category -->
            <div class="task-card-meta">
                <span t-attf-class="badge {{ priorityClass }}">
                    <t t-esc="priorityLabel"/>
                </span>
                <span class="badge badge-category">
                    <t t-esc="categoryLabel"/>
                </span>
            </div>

            <!-- Footer: Assignee + Due Date -->
            <div class="task-card-footer">
                <div class="task-card-assignee">
                    <t t-if="props.task.assignee">
                        <span class="task-card-assignee-avatar" t-esc="assigneeInitials"/>
                        <span t-esc="props.task.assignee"/>
                    </t>
                    <t t-else="">
                        <span style="color: var(--text-muted); font-style: italic;">Unassigned</span>
                    </t>
                </div>
                <t t-if="formattedDueDate">
                    <span t-attf-class="task-card-due {{ formattedDueDate.overdue ? 'overdue' : '' }}">
                        <i class="fa fa-clock-o" aria-hidden="true"/>
                        <t t-esc="formattedDueDate.text"/>
                    </span>
                </t>
            </div>

            <!-- Quick Status Buttons -->
            <div class="task-status-actions">
                <t t-if="prevStatus">
                    <button class="status-move-btn" type="button" t-on-click="onMovePrev">
                        ← <t t-esc="getStatusLabel(prevStatus)"/>
                    </button>
                </t>
                <t t-if="nextStatus">
                    <button class="status-move-btn" type="button" t-on-click="onMoveNext">
                        <t t-esc="getStatusLabel(nextStatus)"/> →
                    </button>
                </t>
            </div>
        </div>
    </t>
</templates>