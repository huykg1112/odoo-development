<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.StatusSettings">
        <div class="modal-overlay">
            <div class="modal modal-lg">
                <div class="modal-header">
                    <h2 class="modal-title">Status Configuration</h2>
                    <button class="btn-icon" type="button" t-on-click="props.onClose" aria-label="Close settings">
                        <i class="fa fa-times" aria-hidden="true"/>
                    </button>
                </div>

                <div class="modal-body">
                    <t t-if="state.loading.initial">
                        <div class="settings-loading" role="status" aria-live="polite">
                            <span class="spinner" aria-hidden="true"/>
                            <span>Loading…</span>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="settings-layout">
                            <!-- List -->
                            <div class="settings-list">
                                <div class="settings-list-header">
                                    <h3 class="settings-title">Statuses</h3>
                                    <button class="btn btn-sm btn-primary" type="button" t-on-click="startCreate" t-if="!isEditing" t-att-disabled="state.loading.saving">
                                        <i class="fa fa-plus" aria-hidden="true"/> New
                                    </button>
                                </div>
                                <div class="status-items" role="list">
                                    <t t-foreach="state.statuses" t-as="status" t-key="status.id">
                                        <div class="status-item-row" role="listitem">
                                            <button type="button"
                                                    t-attf-class="status-item {{ state.editingId === status.id ? 'active' : '' }}"
                                                    t-on-click="() => this.startEdit(status)">
                                                <span class="status-color-dot" t-att-style="'background:' + getColorStyle(status.color)"/>
                                                <span class="status-name" t-esc="status.name"/>
                                            </button>
                                            <button class="btn-icon-sm danger"
                                                    type="button"
                                                    aria-label="Delete status"
                                                    t-on-click.stop="() => this.deleteStatus(status.id)"
                                                    t-att-disabled="state.loading.deletingId === status.id or state.loading.saving"
                                                    t-if="state.editingId !== status.id">
                                                <i class="fa fa-trash" aria-hidden="true"/>
                                            </button>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Edit Form -->
                            <div class="settings-form" t-if="isEditing">
                                <h3 class="settings-title">
                                    <t t-if="state.isCreating">New Status</t>
                                    <t t-else="">Edit Status</t>
                                </h3>
                                
                                <div class="form-group">
                                    <label class="form-label" for="status_name">Name</label>
                                    <input id="status_name" name="status_name" autocomplete="off" type="text" class="form-input"
                                           t-model="state.editData.name"
                                           placeholder="Status name…"/>
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="status_color">Color Index</label>
                                    <input id="status_color" name="status_color" type="number" inputmode="numeric" class="form-input"
                                           t-model="state.editData.color"
                                           min="0" max="10"/>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Allowed Transitions (Move To…)</label>
                                    <div class="transition-checklist">
                                        <t t-foreach="state.statuses" t-as="s" t-key="s.id">
                                            <label class="checkbox-label" t-if="s.id !== state.editingId">
                                                <input type="checkbox"
                                                       t-att-checked="state.editData.transitionIds.includes(s.id)"
                                                       t-on-change="() => this.toggleTransition(s.id)"/>
                                                <span t-esc="s.name"/>
                                            </label>
                                        </t>
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <button class="btn btn-secondary" type="button" t-on-click="cancelEdit" t-att-disabled="state.loading.saving">Cancel</button>
                                    <button class="btn btn-primary" type="button" t-on-click="saveStatus" t-att-disabled="state.loading.saving">
                                        <t t-if="state.loading.saving">
                                            <span class="spinner spinner-sm" aria-hidden="true"/> Saving…
                                        </t>
                                        <t t-else="">Save</t>
                                    </button>
                                </div>
                            </div>
                            <div class="settings-preview" t-else="">
                                <div class="empty-state">Select a status to edit, or create a new one.</div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
