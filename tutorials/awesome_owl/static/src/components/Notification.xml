<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_owl.Notification">
        <div class="toast-container">
            <t t-foreach="props.notifications" t-as="notif" t-key="notif.id">
                <div t-attf-class="toast {{ notif.type }}">
                    <span class="toast-icon">
                        <t t-if="notif.type === 'success'">✓</t>
                        <t t-if="notif.type === 'error'">✕</t>
                        <t t-if="notif.type === 'info'">ℹ</t>
                    </span>
                    <span class="toast-message" t-esc="notif.message"/>
                </div>
            </t>
        </div>
    </t>
</templates>
