<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tạo window Action -->
    <!-- Form View -->
    <record id="view_college_student_form" model="ir.ui.view">
        <field name="name">college.student.form</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <form string="College Student" create="false" edit="true" delete="true">
                <sheet>
                    <field name="image_19209" widget="image" />
                    <group>
                        <group>
                            <field name="admission_number" />
                            <field name="admission_date" />
                            <field name="first_name" />
                            <field name="last_name" />
                            <field name="father_name" />
                        </group>
                        <group>
                            <field name="mother_name" />
                            <field name="date_of_birth" />
                            <field name="communication_address" />
                            <field name="email" />
                            <field name="phone" />
                        </group>
                    </group>
                    <div>
                        <group>
                            <field name="same_as_communication_address" widget="boolean_toggle" />
                        </group>
                    </div>
                    <notebook invisible="not same_as_communication_address">
                        <page name="Contact
                                        Information"
                            string="Contact
                                        Information">
                            <div class="o_address_format">
                                <group>
                                    <field name="street" placeholder="Street..."
                                        class="o_address_street" />
                                    <field name="street2" placeholder="Street 2..."
                                        class="o_address_street" />
                                    <field name="city" placeholder="City" class="o_address_city" />
                                    <field name="state_id" class="o_address_state"
                                        placeholder="State"
                                        options='{"no_open": True}' />
                                    <field name="zip" placeholder="ZIP" class="o_address_zip" />
                                    <field name="country_id" placeholder="Country"
                                        class="o_address_country"
                                        options='{"no_open": True, "no_create": True}' />
                                </group>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_college_erp" model="ir.actions.act_window">
        <field name="name">College ERP</field>
        <field name="res_model">college.student</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_similing_face">Create your student records here.</p>
        </field>
    </record>

</odoo>