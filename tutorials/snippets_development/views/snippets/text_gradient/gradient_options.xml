<odoo>
    <template id="text_gradient_options" inherit_id="website.snippet_options">

        <xpath expr="." position="inside">

            <div data-selector=".o_snippet_gradient">

                <we-title string="Gradient Text"/>

                <!-- Color 1 -->
                <we-colorpicker string="Color 1"
                    data-apply-to=".gradient-text"
                    data-css-property="--g-color-1"
                    data-select-style="true"
                    data-css-compatible="true"
                    data-no-transparency="true"/>

                <!-- Color 2 -->
                <we-colorpicker string="Color 2"
                    data-apply-to=".gradient-text"
                    data-css-property="--g-color-2"
                    data-select-style="true"
                    data-css-compatible="true"
                    data-no-transparency="true"/>

                <!-- Color 3 -->
                <we-colorpicker string="Color 3"
                    data-apply-to=".gradient-text"
                    data-css-property="--g-color-3"
                    data-select-style="true"
                    data-css-compatible="true"
                    data-no-transparency="true"/>

                <!-- Direction -->
                <we-select string="Direction" data-apply-to=".gradient-text">
                    <we-button data-select-style="to right"
                               data-css-property="--g-direction">→</we-button>

                    <we-button data-select-style="to left"
                               data-css-property="--g-direction">←</we-button>

                    <we-button data-select-style="to bottom"
                               data-css-property="--g-direction">↓</we-button>

                    <we-button data-select-style="45deg"
                               data-css-property="--g-direction">↘</we-button>
                </we-select>

                <!-- Font size -->
                <we-select string="Font Size" data-apply-to=".gradient-text">
                    <we-button data-select-style="24px" data-css-property="font-size">S</we-button>
                    <we-button data-select-style="36px" data-css-property="font-size">M</we-button>
                    <we-button data-select-style="48px" data-css-property="font-size">L</we-button>
                    <we-button data-select-style="64px" data-css-property="font-size">XL</we-button>
                </we-select>

                <!-- Font weight -->
                <we-button-group string="Weight" data-apply-to=".gradient-text">
                    <we-button data-select-class="fw-light">L</we-button>
                    <we-button data-select-class="fw-normal">N</we-button>
                    <we-button data-select-class="fw-bold">B</we-button>
                </we-button-group>

            </div>

        </xpath>
    </template>
</odoo>