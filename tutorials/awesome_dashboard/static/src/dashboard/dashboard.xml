<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- xml:space là gì? -->
    <!-- xml:space là một thuộc tính của XML dùng để chỉ định cách xử lý khoảng trắng trong XML. -->
    <!-- preserve: giữ nguyên khoảng trắng -->
    <!-- default: xử lý khoảng trắng theo mặc định -->

    <t t-name="awesome_dashboard.AwesomeDashboard">
        <Layout display="{ controlPanel: {} }" className="'o-dashboard h-100 overflow-auto '"> <!-- Sử dụng component Layout để tạo bố cục cho
            dashboard, với controlPanel trống vì chúng ta sẽ không sử dụng thanh công cụ mặc định
            của Odoo -->   
            <t t-set-slot="layout-buttons" > <!-- Sử dụng slot layout-buttons để chèn các
                nút điều khiển vào thanh công cụ của layout -->
                <button class="btn btn-primary" t-on-click="openCustomers">
                    Customers
                </button>
                <button class="btn btn-secondary ms-2" t-on-click="openLeads">
                    Leads
                </button>
                <button class="btn btn-light ms-2" t-on-click="openSettings" title="Settings">
                    <i class="fa fa-cog"/>
                </button>
            </t>
            <div class="o_dashboard_content d-flex flex-wrap gap-3 p-3">
                <t t-foreach="items" t-as="item" t-key="item.id">
                    <DashboardItem size="item.size || 1">
                        <t t-set="itemProp" t-value="item.props ? item.props(statistics) : {'data': statistics}"/>
                        <t t-component="item.Component" t-props="itemProp"/>
                    </DashboardItem>
                </t>
            </div>
            <div class="d-flex justify-content-around gap-3 p-3 mb-5">
                <DashboardItem width="'600px'">
                    <h5 class="card-title">T-Shirts by Size</h5>
                    <t t-if="statistics.orders_by_size">
                        <PieChart data="statistics.orders_by_size"/>
                    </t>
                </DashboardItem>

                <!-- lấy 3 size sum lại kết quả ra chẵn hay lẽ -->
                 <DashboardItem>
                    <t t-if="statistics.orders_by_size">
                        <t t-if="totalSize % 2 == 0">
                            <h1><p class="text-danger">Chẵn</p> (Tổng: <t t-esc="totalSize"/>)</h1>
                        </t>
                        <t t-else="">
                            <h1><p class="text-primary">Lẻ</p> (Tổng: <t t-esc="totalSize"/>)</h1>
                        </t>
                    </t>
                 </DashboardItem>
            </div>

        </Layout>
    </t>

</templates>