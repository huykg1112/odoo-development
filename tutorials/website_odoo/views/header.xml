<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <template id="custom_header" inherit_id="website.layout" name="Website Odoo Training Ribbon">
        <xpath expr="//header//nav" position="replace">
            <header class="fixed-top w-100 bg-white bg-opacity-75 shadow-sm"
                style="backdrop-filter: blur(10px); z-index: 1050;">
                <div class="container d-flex align-items-center justify-content-between"
                    style="height: 80px;">

                    <!-- Logo -->
                    <div class="d-flex align-items-center gap-2 fw-bold fs-4 text-dark">
                        <span class="material-symbols-outlined text-primary fs-2">
                            dentistry
                        </span>
                        <span>Luminous Dental</span>
                    </div>

                    <!-- Nav -->
                    <nav class="d-none d-md-flex align-items-center gap-4">
                        <a class="text-primary fw-semibold text-decoration-none" href="#">Trang chủ</a>
                        <a class="text-secondary text-decoration-none hover-primary" href="#">Dịch
                            vụ</a>
                        <a class="text-secondary text-decoration-none hover-primary" href="#">Đội
                            ngũ</a>
                        <a class="text-secondary text-decoration-none hover-primary" href="#">Liên
                            hệ</a>
                    </nav>

                    <!-- Actions -->
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-primary rounded-pill px-4 d-none d-md-block">
                            Đặt lịch
                        </button>

                        <button class="btn d-md-none p-2">
                            <span class="material-symbols-outlined">menu</span>
                        </button>
                    </div>

                </div>
            </header>
        </xpath>
    </template>
</odoo>