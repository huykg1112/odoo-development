<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        STAGE 1 - Layout inheritance
        Khong replace toan bo header/nav vi de gay khi core doi DOM.
        Thay vao do, chen 1 ribbon nho vao layout de minh hoa xpath on dinh.
    -->
    <template id="custom_header" inherit_id="website.layout" name="Website Odoo Training Ribbon">
        <xpath expr="//header//nav" position="replace">
            <header
                class="fixed top-0 w-full z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md shadow-sm dark:shadow-none"
            >
                <div
                    class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
                >
                    <div
                        class="flex items-center gap-2 text-xl font-extrabold text-slate-900 dark:text-white font-headline tracking-tight"
                    >
                        <span
                            class="material-symbols-outlined text-primary text-3xl"
                            data-icon="dentistry"
                        >dentistry</span>

                        <span>Luminous Dental</span>
                    </div>

                    <nav class="hidden md:flex items-center gap-8">
                        <a
                            class="text-blue-600 dark:text-blue-400 font-semibold font-headline transition-colors"
                            href="#"
                        >Trang chủ</a>

                        <a
                            class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-headline"
                            href="#"
                        >Dịch vụ</a>

                        <a
                            class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-headline"
                            href="#"
                        >Đội ngũ</a>

                        <a
                            class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-headline"
                            href="#"
                        >Liên hệ</a>
                    </nav>

                    <div class="flex items-center gap-4">
                        <button
                            class="hidden md:block bg-primary text-on-primary px-6 py-2.5 rounded-full font-semibold hover:opacity-90 transition-all scale-95 active:duration-100"
                        >
                            Đặt lịch
                        </button>

                        <button class="md:hidden text-on-surface p-2">
                            <span class="material-symbols-outlined" data-icon="menu">menu</span>
                        </button>
                    </div>
                </div>
            </header>
        </xpath>
    </template>
</odoo>