<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_footer" inherit_id="website.layout" name="Custom Footer">
        <xpath expr="//footer" position="replace">
            <footer class="bg-dark text-white w-100 pt-5 pb-4">
                <div class="container">
                    <div class="row g-5">

                        <!-- Column 1 -->
                        <div class="col-12 col-md-3">
                            <div class="d-flex align-items-center gap-2 mb-4 fw-bold fs-5">
                                <span class="material-symbols-outlined text-primary">
                                    dentistry
                                </span>
                                <span>Luminous Dental</span>
                            </div>

                            <p class="text-secondary small mb-4">
                                Kiến tạo nụ cười hoàn mỹ với công nghệ nha khoa hàng đầu thế giới.
                                Chúng tôi tự hào là người bạn đồng hành tin cậy của gia đình Việt.
                            </p>

                            <div class="d-flex gap-3">
                                <a class="social-icon" href="#">
                                    <span class="material-symbols-outlined">social_leaderboard</span>
                                </a>

                                <a class="social-icon" href="#">
                                    <span class="material-symbols-outlined">chat</span>
                                </a>
                            </div>
                        </div>

                        <!-- Column 2 -->
                        <div class="col-6 col-md-3">
                            <h4 class="fw-bold mb-4">Menu</h4>
                            <ul class="list-unstyled">
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Trang chủ</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Về chúng tôi</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Đội ngũ bác sĩ</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Blog sức khỏe</a>
                                </li>
                            </ul>
                        </div>

                        <!-- Column 3 -->
                        <div class="col-6 col-md-3">
                            <h4 class="fw-bold mb-4">Dịch vụ</h4>
                            <ul class="list-unstyled">
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Niềng răng Invisalign</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Răng sứ thẩm mỹ</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Nhổ răng khôn</a>
                                </li>
                                <li class="mb-3">
                                    <a class="footer-link" href="#">Tẩy trắng răng</a>
                                </li>
                            </ul>
                        </div>

                        <!-- Column 4 -->
                        <div class="col-12 col-md-3">
                            <h4 class="fw-bold mb-4">Liên hệ</h4>
                            <ul class="list-unstyled small text-secondary">
                                <li class="d-flex gap-2 mb-3">
                                    <span class="material-symbols-outlined text-primary">location_on</span>
                                    <span>123 Đường Nguyễn Huệ, Quận 1, TP. Hồ Chí Minh</span>
                                </li>

                                <li class="d-flex gap-2 mb-3">
                                    <span class="material-symbols-outlined text-primary">phone</span>
                                    <span>1800 6868</span>
                                </li>

                                <li class="d-flex gap-2 mb-3">
                                    <span class="material-symbols-outlined text-primary">mail</span>
                                    <span>contact@luminousdental.vn</span>
                                </li>
                            </ul>
                        </div>

                    </div>

                    <!-- Bottom -->
                    <div
                        class="border-top border-secondary mt-5 pt-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                        <p class="text-secondary small text-center mb-0">
                            © 2024 Luminous Sanctuary Dental. All rights reserved.
                        </p>

                        <div class="d-flex gap-4">
                            <a class="footer-link small" href="#">Chính sách bảo mật</a>
                            <a class="footer-link small" href="#">Điều khoản sử dụng</a>
                            <a class="footer-link small" href="#">Câu hỏi thường gặp</a>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>